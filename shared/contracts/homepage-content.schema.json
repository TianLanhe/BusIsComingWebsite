{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busiscoming.local/contracts/homepage-content.schema.json",
  "title": "BusIsComing Homepage Content Contract",
  "type": "object",
  "required": [
    "metadata",
    "navigation",
    "hero",
    "featureShowcase",
    "features",
    "onlineQueryDemo",
    "downloadSection",
    "faq",
    "contact",
    "scopeExclusions",
    "homepageExperience",
    "figmaReference"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated", "sourceReferences"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "lastUpdated": { "type": "string", "format": "date" },
        "sourceReferences": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "navigation": {
      "type": "object",
      "required": ["brand", "items", "languageLabel"],
      "properties": {
        "brand": { "$ref": "#/$defs/localizedString" },
        "items": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "required": ["id", "label", "target"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "label": { "$ref": "#/$defs/localizedString" },
              "target": { "type": "string", "pattern": "^#" }
            },
            "additionalProperties": false
          }
        },
        "languageLabel": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "hero": {
      "type": "object",
      "required": ["headline", "subheading", "bullets", "primaryAction", "secondaryAction", "apkMeta", "iphoneStatus"],
      "properties": {
        "headline": { "$ref": "#/$defs/localizedString" },
        "subheading": { "$ref": "#/$defs/localizedString" },
        "bullets": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/textPair" }
        },
        "primaryAction": { "$ref": "#/$defs/action" },
        "secondaryAction": { "$ref": "#/$defs/action" },
        "apkMeta": { "$ref": "#/$defs/localizedString" },
        "iphoneStatus": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "featureShowcase": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/featureShowcaseItem" }
    },
    "features": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/featureItem" }
    },
    "onlineQueryDemo": {
      "type": "object",
      "required": [
        "title",
        "description",
        "limitationNotice",
        "initialEmptyTitle",
        "initialEmptyDescription",
        "noRoutesTitle",
        "noRoutesDescription",
        "scopeNotice"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "limitationNotice": { "$ref": "#/$defs/localizedString" },
        "initialEmptyTitle": { "$ref": "#/$defs/localizedString" },
        "initialEmptyDescription": { "$ref": "#/$defs/localizedString" },
        "noRoutesTitle": { "$ref": "#/$defs/localizedString" },
        "noRoutesDescription": { "$ref": "#/$defs/localizedString" },
        "scopeNotice": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "downloadSection": {
      "type": "object",
      "required": ["title", "description", "manifestRef", "androidCard", "iphoneStatus"],
      "properties": {
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "manifestRef": { "type": "string", "minLength": 1 },
        "androidCard": {
          "type": "object",
          "required": ["title", "meta", "primaryAction", "backupAction"],
          "properties": {
            "title": { "$ref": "#/$defs/localizedString" },
            "meta": { "$ref": "#/$defs/localizedString" },
            "primaryAction": { "$ref": "#/$defs/action" },
            "backupAction": { "$ref": "#/$defs/action" }
          },
          "additionalProperties": false
        },
        "iphoneStatus": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "faq": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/faqItem" }
    },
    "contact": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contactEntry" }
    },
    "scopeExclusions": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/localizedString" }
    },
    "homepageExperience": { "$ref": "#/$defs/homepageExperience" },
    "figmaReference": {
      "type": "object",
      "required": ["fileUrl", "pageNode", "desktopNode", "mobileNode", "downloadStatesNode", "carouselStatesNode", "notesNode", "versionNote"],
      "properties": {
        "fileUrl": { "type": "string", "format": "uri" },
        "pageNode": { "type": "string", "minLength": 1 },
        "desktopNode": { "type": "string", "minLength": 1 },
        "mobileNode": { "type": "string", "minLength": 1 },
        "downloadStatesNode": { "type": "string", "minLength": 1 },
        "carouselStatesNode": { "type": "string", "minLength": 1 },
        "notesNode": { "type": "string", "minLength": 1 },
        "versionNote": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "localizedString": {
      "type": "object",
      "required": ["zh-Hant", "zh-Hans", "en"],
      "properties": {
        "zh-Hant": { "type": "string", "minLength": 1 },
        "zh-Hans": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "textPair": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["label", "target"],
      "properties": {
        "label": { "$ref": "#/$defs/localizedString" },
        "target": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["download", "anchor", "external"] },
        "downloadFileName": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "featureShowcaseItem": {
      "type": "object",
      "required": ["id", "order", "title", "description", "gallery", "sourceReference", "autoCarouselEligible"],
      "properties": {
        "id": {
          "enum": [
            "favorite-citybus-routes",
            "route-comparison",
            "eta-details",
            "predeparture-monitor"
          ]
        },
        "order": { "type": "integer", "minimum": 1, "maximum": 4 },
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "gallery": {
          "type": "object",
          "required": [
            "featureId",
            "defaultImageId",
            "manualOnly",
            "hideStackWhenSingleImage",
            "visualMode",
            "allowThumbnailControls",
            "images"
          ],
          "properties": {
            "featureId": {
              "enum": [
                "favorite-citybus-routes",
                "route-comparison",
                "eta-details",
                "predeparture-monitor"
              ]
            },
            "defaultImageId": { "type": "string", "minLength": 1 },
        "manualOnly": { "const": true },
        "hideStackWhenSingleImage": { "const": true },
        "visualMode": { "const": "stair-card-deck" },
        "allowThumbnailControls": { "const": false },
        "images": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/screenshotAsset" }
            }
          },
          "additionalProperties": false
        },
        "sourceReference": { "type": "string", "minLength": 1 },
        "autoCarouselEligible": { "const": true }
      },
      "additionalProperties": false
    },
    "screenshotAsset": {
      "type": "object",
      "required": [
        "id",
        "sourcePath",
        "assetPath",
        "src",
        "order",
        "isDefault",
        "desensitizationStatus",
        "redactedItems",
        "retainedItems",
        "alt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sourcePath": { "type": "string", "minLength": 1 },
        "assetPath": {
          "type": "string",
          "pattern": "^frontend/src/assets/app-screenshots/real/.+\\.(webp|jpg|jpeg|png)$"
        },
        "src": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 1 },
        "isDefault": { "type": "boolean" },
        "desensitizationStatus": { "enum": ["pending", "approved", "rejected"] },
        "redactedItems": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "retainedItems": {
          "type": "array",
          "contains": { "const": "price-time-eta-values" },
          "items": { "type": "string", "minLength": 1 }
        },
        "alt": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "featureItem": {
      "type": "object",
      "required": ["id", "title", "description", "icon", "sourceReference"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "icon": { "type": "string", "minLength": 1 },
        "sourceReference": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "demoRouteResult": {
      "type": "object",
      "required": ["routeNumber", "operator", "fare", "duration", "walkingDistance", "etaDisplay"],
      "properties": {
        "routeNumber": { "type": "string", "minLength": 1 },
        "operator": { "type": "string", "minLength": 1 },
        "fare": { "type": "string", "pattern": "^HK\\$" },
        "duration": { "$ref": "#/$defs/localizedString" },
        "walkingDistance": { "$ref": "#/$defs/localizedString" },
        "etaDisplay": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "faqItem": {
      "type": "object",
      "required": ["id", "category", "question", "answer"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "category": { "enum": ["android-install", "ios-status", "online-query-limit", "data-scope", "other"] },
        "question": { "$ref": "#/$defs/localizedString" },
        "answer": { "$ref": "#/$defs/localizedString" }
      },
      "additionalProperties": false
    },
    "contactEntry": {
      "type": "object",
      "required": ["id", "label", "description", "href", "priority"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "href": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["secondary"] }
      },
      "additionalProperties": false
    },
    "homepageExperience": {
      "type": "object",
      "required": ["metadata", "carousel", "brandLogo", "contact", "localizedCopyReview", "figmaReference"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["version", "lastUpdated"],
          "properties": {
            "version": { "type": "string", "pattern": "^2026-06-24\\.homepage-experience-polish" },
            "lastUpdated": { "type": "string", "format": "date" }
          },
          "additionalProperties": false
        },
        "carousel": {
          "type": "object",
          "required": [
            "autoAdvanceMs",
            "featureOrder",
            "visualMode",
            "supportsSwipe",
            "supportsDesktopDrag",
            "supportsKeyboardSwitching",
            "showsNumericLabels",
            "usesThumbnailStack",
            "usesPersistentArrows"
          ],
          "properties": {
            "autoAdvanceMs": { "const": 3000 },
            "featureOrder": {
              "type": "array",
              "prefixItems": [
                { "const": "favorite-citybus-routes" },
                { "const": "route-comparison" },
                { "const": "eta-details" },
                { "const": "predeparture-monitor" }
              ],
              "minItems": 4,
              "maxItems": 4
            },
            "visualMode": { "const": "stair-card-deck" },
            "supportsSwipe": { "const": true },
            "supportsDesktopDrag": { "const": true },
            "supportsKeyboardSwitching": { "const": true },
            "showsNumericLabels": { "const": false },
            "usesThumbnailStack": { "const": false },
            "usesPersistentArrows": { "const": false }
          },
          "additionalProperties": false
        },
        "brandLogo": {
          "type": "object",
          "required": ["sourcePath", "outputPath", "backgroundRemoved", "transparent", "usesLauncherPlate", "placements"],
          "properties": {
            "sourcePath": {
              "type": "string",
              "pattern": "app/src/main/res/mipmap-xxxhdpi/ic_launcher_foreground\\.png$"
            },
            "outputPath": {
              "type": "string",
              "pattern": "^frontend/src/assets/brand/.+\\.(png|webp)$"
            },
            "backgroundRemoved": { "const": true },
            "transparent": { "const": true },
            "usesLauncherPlate": { "const": false },
            "placements": {
              "type": "array",
              "allOf": [
                { "contains": { "const": "header" } },
                { "contains": { "const": "footer" } }
              ],
              "items": { "enum": ["header", "footer", "favicon"] },
              "uniqueItems": true,
              "minItems": 2
            }
          },
          "additionalProperties": false
        },
        "contact": {
          "type": "object",
          "required": ["navLabel", "email", "href"],
          "properties": {
            "navLabel": {
              "type": "object",
              "required": ["zh-Hant", "zh-Hans", "en"],
              "properties": {
                "zh-Hant": { "const": "聯絡我們" },
                "zh-Hans": { "const": "联系我们" },
                "en": { "const": "Contact Us" }
              },
              "additionalProperties": false
            },
            "email": { "const": "hezhenyu966@gmail.com" },
            "href": { "const": "mailto:hezhenyu966@gmail.com" }
          },
          "additionalProperties": false
        },
        "localizedCopyReview": {
          "type": "object",
          "required": ["scope", "zhHantTone", "allLocalesRequired"],
          "properties": {
            "scope": {
              "type": "array",
              "minItems": 8,
              "items": {
                "enum": [
                  "navigation",
                  "hero",
                  "carousel",
                  "features",
                  "online-query",
                  "download",
                  "faq",
                  "footer",
                  "status",
                  "accessibility"
                ]
              }
            },
            "zhHantTone": { "const": "hong-kong-practical-written" },
            "allLocalesRequired": {
              "type": "array",
              "prefixItems": [
                { "const": "zh-Hant" },
                { "const": "zh-Hans" },
                { "const": "en" }
              ],
              "minItems": 3,
              "maxItems": 3
            }
          },
          "additionalProperties": false
        },
        "figmaReference": {
          "type": "object",
          "required": ["fileUrl", "pluginPath", "pageName", "nodeNames"],
          "properties": {
            "fileUrl": { "type": "string", "format": "uri" },
            "pluginPath": { "const": "specs/005-homepage-experience-polish/figma-plugin/manifest.json" },
            "pageName": { "const": "Homepage Experience Polish - 005" },
            "nodeNames": {
              "type": "array",
              "minItems": 5,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
