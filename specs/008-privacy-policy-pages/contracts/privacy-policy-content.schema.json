{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.busiscoming.com/contracts/privacy-policy-content.schema.json",
  "title": "BusIsComing Privacy Policy Content Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["privacyPolicy", "seoPageGroups", "footerPrivacyLinks"],
  "properties": {
    "privacyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata", "hero", "summaryCards", "sections"],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "lastUpdated", "contactEmail", "appliesTo"],
          "properties": {
            "version": { "type": "string", "minLength": 1 },
            "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "contactEmail": { "const": "hezhenyu966@gmail.com" },
            "appliesTo": {
              "type": "array",
              "minItems": 2,
              "items": { "enum": ["website", "android-app"] },
              "uniqueItems": true
            }
          }
        },
        "hero": {
          "type": "object",
          "additionalProperties": false,
          "required": ["eyebrow", "title", "lead"],
          "properties": {
            "eyebrow": { "$ref": "#/$defs/localizedString" },
            "title": { "$ref": "#/$defs/localizedString" },
            "lead": { "$ref": "#/$defs/localizedString" }
          }
        },
        "summaryCards": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "$ref": "#/$defs/summaryCard" }
        },
        "sections": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/policySection" }
        }
      }
    },
    "seoPageGroups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home", "privacy"],
      "properties": {
        "home": { "$ref": "#/$defs/seoPageGroup" },
        "privacy": { "$ref": "#/$defs/seoPageGroup" }
      }
    },
    "footerPrivacyLinks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zh-Hant", "zh-Hans", "en"],
      "properties": {
        "zh-Hant": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "href"],
          "properties": {
            "label": { "const": "私隱政策" },
            "href": { "const": "/zh-hant/privacy/" }
          }
        },
        "zh-Hans": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "href"],
          "properties": {
            "label": { "const": "隐私政策" },
            "href": { "const": "/zh-hans/privacy/" }
          }
        },
        "en": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "href"],
          "properties": {
            "label": { "const": "Privacy Policy" },
            "href": { "const": "/en/privacy/" }
          }
        }
      }
    }
  },
  "$defs": {
    "localizedString": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zh-Hant", "zh-Hans", "en"],
      "properties": {
        "zh-Hant": { "type": "string", "minLength": 1 },
        "zh-Hans": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "summaryCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "title", "description"],
      "properties": {
        "id": {
          "enum": [
            "no-account-identity",
            "no-ads-sale",
            "device-first-saved-routes",
            "external-services-as-needed"
          ]
        },
        "order": { "type": "integer", "minimum": 1, "maximum": 4 },
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" }
      }
    },
    "policySection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "title", "paragraphs", "requiredFacts"],
      "properties": {
        "id": {
          "enum": [
            "scope",
            "what-we-do-not-collect",
            "functional-processing",
            "third-party-services",
            "your-choices"
          ]
        },
        "order": { "type": "integer", "minimum": 1, "maximum": 5 },
        "title": { "$ref": "#/$defs/localizedString" },
        "paragraphs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/localizedString" }
        },
        "bullets": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedString" }
        },
        "requiredFacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "website",
              "android-app",
              "no-account",
              "no-ad-tracking",
              "no-sale",
              "route-query-data",
              "gps-coordinate",
              "google-geocoding-api",
              "citybus",
              "data-gov-hk",
              "short-term-service-logs",
              "device-local-saved-routes",
              "notification-monitoring",
              "speech-reminders",
              "user-controls",
              "contact-email"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "seoPageGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageId", "defaultLocale", "xDefault", "locales", "changefreq", "priority"],
      "properties": {
        "pageId": { "enum": ["home", "privacy"] },
        "defaultLocale": { "const": "zh-Hant" },
        "xDefault": { "type": "string", "format": "uri" },
        "changefreq": { "enum": ["weekly", "monthly", "yearly"] },
        "priority": { "type": "number", "minimum": 0, "maximum": 1 },
        "locales": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zh-Hant", "zh-Hans", "en"],
          "properties": {
            "zh-Hant": { "$ref": "#/$defs/seoPageLocale" },
            "zh-Hans": { "$ref": "#/$defs/seoPageLocale" },
            "en": { "$ref": "#/$defs/seoPageLocale" }
          }
        }
      }
    },
    "seoPageLocale": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "htmlLang",
        "canonical",
        "title",
        "description",
        "ogTitle",
        "ogDescription",
        "twitterTitle",
        "twitterDescription"
      ],
      "properties": {
        "path": { "type": "string", "pattern": "^/(zh-hant|zh-hans|en)/(|privacy/)$" },
        "htmlLang": { "enum": ["zh-Hant", "zh-Hans", "en"] },
        "canonical": { "type": "string", "format": "uri" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "ogTitle": { "type": "string", "minLength": 1 },
        "ogDescription": { "type": "string", "minLength": 1 },
        "twitterTitle": { "type": "string", "minLength": 1 },
        "twitterDescription": { "type": "string", "minLength": 1 }
      }
    }
  }
}
