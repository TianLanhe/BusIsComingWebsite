{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busiscoming.local/contracts/homepage-ui-polish-content.schema.json",
  "title": "BusIsComing Homepage UI Polish Content Contract",
  "type": "object",
  "required": ["metadata", "heroGallery", "featureGrid", "routeResultCard", "fareCopy", "figmaReference"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "const": "2026-06-27.homepage-ui-polish" },
        "lastUpdated": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "heroGallery": {
      "type": "object",
      "required": ["desktopScale", "showZoomIndicator", "splitGestureZones", "lightbox"],
      "properties": {
        "desktopScale": { "enum": ["medium"] },
        "showZoomIndicator": { "const": false },
        "splitGestureZones": {
          "type": "object",
          "required": ["screenshotZoneAction", "copyZoneAction"],
          "properties": {
            "screenshotZoneAction": { "const": "switch-same-feature-image" },
            "copyZoneAction": { "const": "switch-feature" }
          },
          "additionalProperties": false
        },
        "lightbox": {
          "type": "object",
          "required": ["enabled", "sameFeatureOnly", "supportsZoom", "supportsPan", "supportsKeyboardClose", "controls"],
          "properties": {
            "enabled": { "const": true },
            "sameFeatureOnly": { "const": true },
            "supportsZoom": { "const": true },
            "supportsPan": { "const": true },
            "supportsKeyboardClose": { "const": true },
            "controls": {
              "type": "object",
              "required": ["close", "zoomIn", "zoomOut", "resetZoom", "previousImage", "nextImage"],
              "properties": {
                "close": { "$ref": "#/$defs/localizedString" },
                "zoomIn": { "$ref": "#/$defs/localizedString" },
                "zoomOut": { "$ref": "#/$defs/localizedString" },
                "resetZoom": { "$ref": "#/$defs/localizedString" },
                "previousImage": { "$ref": "#/$defs/localizedString" },
                "nextImage": { "$ref": "#/$defs/localizedString" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "featureGrid": {
      "type": "object",
      "required": ["mobileColumns", "desktopUnchanged", "minimumFeatureCount", "futureFeatureCount"],
      "properties": {
        "mobileColumns": { "const": 2 },
        "desktopUnchanged": { "const": true },
        "minimumFeatureCount": { "type": "integer", "minimum": 6 },
        "futureFeatureCount": { "type": "integer", "minimum": 10 }
      },
      "additionalProperties": false
    },
    "routeResultCard": {
      "type": "object",
      "required": ["mobileCompact", "desktopUnchanged", "metricLayout", "metrics", "missingStopFallback"],
      "properties": {
        "mobileCompact": { "const": true },
        "desktopUnchanged": { "const": true },
        "metricLayout": { "const": "inline-label-value" },
        "missingStopFallback": { "$ref": "#/$defs/localizedString" },
        "metrics": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["id", "label", "valueStyle"],
            "properties": {
              "id": { "enum": ["fare", "duration", "walking"] },
              "label": { "$ref": "#/$defs/localizedString" },
              "valueStyle": { "const": "emphasized" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "fareCopy": {
      "type": "object",
      "required": ["title", "description", "forbiddenPhrases"],
      "properties": {
        "title": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "forbiddenPhrases": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "figmaReference": {
      "type": "object",
      "required": ["fileUrl", "pageName", "nodeNames", "nodeIds", "nodeIdsResolved"],
      "properties": {
        "fileUrl": { "type": "string", "format": "uri" },
        "pageName": { "const": "Homepage UI Polish - 007" },
        "nodeNames": {
          "type": "array",
          "minItems": 6,
          "items": { "type": "string", "minLength": 1 }
        },
        "nodeIds": {
          "type": "object",
          "required": [
            "Desktop 1440 / Hero Medium Screenshot Deck",
            "Desktop 1440 / Screenshot Lightbox",
            "Mobile 390 / Compact Feature Grid",
            "Mobile 390 / Compact Route Result Card",
            "Interaction States / Split Gesture Zones",
            "Spec Notes"
          ],
          "properties": {
            "Desktop 1440 / Hero Medium Screenshot Deck": { "const": "51:86" },
            "Desktop 1440 / Screenshot Lightbox": { "const": "51:113" },
            "Mobile 390 / Compact Feature Grid": { "const": "51:125" },
            "Mobile 390 / Compact Route Result Card": { "const": "51:151" },
            "Interaction States / Split Gesture Zones": { "const": "51:183" },
            "Spec Notes": { "const": "51:194" }
          },
          "additionalProperties": false
        },
        "nodeIdsResolved": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "localizedString": {
      "type": "object",
      "required": ["zh-Hant", "zh-Hans", "en"],
      "properties": {
        "zh-Hant": { "type": "string", "minLength": 1 },
        "zh-Hans": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
