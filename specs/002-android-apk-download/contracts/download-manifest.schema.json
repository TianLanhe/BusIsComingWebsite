{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busiscoming.local/contracts/android-apk-download-manifest.schema.json",
  "title": "BusIsComing Android APK Download Manifest Contract",
  "type": "object",
  "required": ["version", "lastUpdated", "platforms"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastUpdated": { "type": "string", "format": "date" },
    "platforms": {
      "type": "object",
      "required": ["android", "ios"],
      "properties": {
        "android": { "$ref": "#/$defs/platform" },
        "ios": { "$ref": "#/$defs/platform" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "localizedString": {
      "type": "object",
      "required": ["zh-Hant", "zh-Hans", "en"],
      "properties": {
        "zh-Hant": { "type": "string", "minLength": 1 },
        "zh-Hans": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": [
        "appName",
        "applicationId",
        "versionName",
        "versionCode",
        "fileName",
        "sizeBytes",
        "sizeLabel",
        "sha256",
        "lastUpdated"
      ],
      "properties": {
        "appName": { "type": "string", "minLength": 1 },
        "applicationId": { "type": "string", "minLength": 1 },
        "versionName": { "type": "string", "minLength": 1 },
        "versionCode": { "type": "integer", "minimum": 1 },
        "fileName": { "type": "string", "minLength": 1 },
        "sizeBytes": { "type": "integer", "minimum": 1 },
        "sizeLabel": { "$ref": "#/$defs/localizedString" },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "lastUpdated": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "platform": {
      "type": "object",
      "required": [
        "platform",
        "status",
        "label",
        "description",
        "actionLabel",
        "downloadUrl",
        "disabledReason",
        "artifact"
      ],
      "properties": {
        "platform": { "enum": ["android", "ios"] },
        "status": { "enum": ["available", "unsupported", "temporarily-unavailable"] },
        "label": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "actionLabel": { "$ref": "#/$defs/localizedString" },
        "downloadUrl": {
          "anyOf": [
            { "type": "string", "pattern": "^/api/downloads/android/latest$" },
            { "type": "null" }
          ]
        },
        "disabledReason": {
          "anyOf": [
            { "$ref": "#/$defs/localizedString" },
            { "type": "null" }
          ]
        },
        "artifact": {
          "anyOf": [
            { "$ref": "#/$defs/artifact" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "platform": { "const": "android" },
              "status": { "const": "available" }
            }
          },
          "then": {
            "properties": {
              "downloadUrl": { "type": "string", "pattern": "^/api/downloads/android/latest$" },
              "disabledReason": { "type": "null" },
              "artifact": { "$ref": "#/$defs/artifact" }
            }
          }
        },
        {
          "if": {
            "properties": { "platform": { "const": "ios" } }
          },
          "then": {
            "properties": {
              "status": { "const": "unsupported" },
              "downloadUrl": { "type": "null" },
              "artifact": { "type": "null" }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}

