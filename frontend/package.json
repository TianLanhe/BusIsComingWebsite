{
  "name": "busiscoming-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "openapi:lint": "redocly lint ../shared/contracts/openapi/download-api.openapi.yaml",
    "openapi:bundle": "redocly bundle ../shared/contracts/openapi/download-api.openapi.yaml -o ../shared/contracts/openapi/download-api.bundle.yaml",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@redocly/cli": "^2.32.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "yaml": "^2.9.0"
  }
}
